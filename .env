# ============================================================================
#  GigaChat (LLM + Embeddings)
# ============================================================================
# Authorization key из личного кабинета developers.sber.ru
# (base64 от "client_id:client_secret"). НИКОГДА не коммитьте реальный ключ.
GIGACHAT_CREDENTIALS=YOUR_AUTHORIZATION_KEY

# Область доступа. Для физлиц — GIGACHAT_API_PERS.
# Возможные значения: GIGACHAT_API_PERS | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Модель чата.
GIGACHAT_MODEL=GigaChat-Max

# Модель эмбеддингов: EmbeddingsGigaR (рекомендуется для RAG) | Embeddings
GIGACHAT_EMBEDDINGS_MODEL=EmbeddingsGigaR

# Проверка SSL-сертификата GigaChat.
#   true  — требует корневой сертификат "Russian Trusted Root CA" в системе
#           (он устанавливается в Docker-образ автоматически).
#   false — отключить проверку (быстро, менее безопасно; ок для локального теста).
GIGACHAT_VERIFY_SSL=false   # поставил так как это прототип

# ============================================================================
#  Qdrant (векторное хранилище) — два варианта подключения
# ============================================================================
# --- Вариант A: локальный контейнер (по умолчанию, самодостаточно) ---
# В docker-compose host = "qdrant"; при запуске вне Docker = "localhost".
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=transform_kb

# --- Вариант B: Qdrant Cloud (управляемый) ---
# Если заданы QDRANT_URL и QDRANT_API_KEY — приложение и seed.py пойдут в облако,
# а локальный контейнер qdrant не используется. URL обязательно с портом :6333.
# QDRANT_URL=
# QDRANT_API_KEY=

# ============================================================================
#  RAG / приложение
# ============================================================================
# Сколько кейсов из базы знаний подмешивать в контекст LLM.
RAG_TOP_K=5

# Авто-сид при старте: если true и коллекция ещё не создана — приложение само
# заполнит базу знаний при запуске (тогда `docker compose up` стартует всё одной
# командой). Если false — базу нужно залить вручную: python seed.py
SEED_ON_START=true
